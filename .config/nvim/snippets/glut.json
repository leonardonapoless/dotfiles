{
    "GLUT Bootstrap (macOS)": {
        "prefix": [
            "glut_main",
            "main_glut"
        ],
        "body": [
            "#include <stdio.h>",
            "#include <stdlib.h>",
            "#include <math.h>",
            "#define GL_SILENCE_DEPRECATION",
            "#ifdef __APPLE__",
            "    #include <GLUT/glut.h>",
            "#else",
            "    #include <GL/glut.h>",
            "#endif",
            "",
            "void display(void)",
            "{",
            "    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);",
            "",
            "    // Draw here",
            "    $0",
            "",
            "    glutSwapBuffers();",
            "}",
            "",
            "void reshape(int w, int h)",
            "{",
            "    glViewport(0, 0, w, h);",
            "    glMatrixMode(GL_PROJECTION);",
            "    glLoadIdentity();",
            "    gluPerspective(45.0, (double)w / (double)h, 0.1, 100.0);",
            "    glMatrixMode(GL_MODELVIEW);",
            "}",
            "",
            "void keyboard(unsigned char key, int x, int y)",
            "{",
            "    if (key == 27) exit(0); // ESC to quit",
            "}",
            "",
            "int main(int argc, char** argv)",
            "{",
            "    glutInit(&argc, argv);",
            "    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB | GLUT_DEPTH);",
            "    glutInitWindowSize(${1:800}, ${2:600});",
            "    glutCreateWindow(\"${3:GLUT App}\");",
            "",
            "    glEnable(GL_DEPTH_TEST);",
            "    glClearColor(0.1f, 0.1f, 0.1f, 1.0f);",
            "",
            "    glutDisplayFunc(display);",
            "    glutReshapeFunc(reshape);",
            "    glutKeyboardFunc(keyboard);",
            "",
            "    glutMainLoop();",
            "    return 0;",
            "}"
        ],
        "description": "Complete GLUT bootstrap with display, reshape, and keyboard callbacks"
    },
    "GLUT Display Callback": {
        "prefix": [
            "glut_display",
            "display_func"
        ],
        "body": [
            "void ${1:display}(void)",
            "{",
            "    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);",
            "    glLoadIdentity();",
            "",
            "    $0",
            "",
            "    glutSwapBuffers();",
            "}"
        ],
        "description": "GLUT display callback function"
    },
    "GLUT Reshape Callback": {
        "prefix": [
            "glut_reshape",
            "reshape_func"
        ],
        "body": [
            "void ${1:reshape}(int w, int h)",
            "{",
            "    if (h == 0) h = 1;",
            "    glViewport(0, 0, w, h);",
            "    glMatrixMode(GL_PROJECTION);",
            "    glLoadIdentity();",
            "    gluPerspective(${2:45.0}, (double)w / (double)h, ${3:0.1}, ${4:100.0});",
            "    glMatrixMode(GL_MODELVIEW);",
            "    glLoadIdentity();",
            "}"
        ],
        "description": "GLUT reshape callback with perspective projection"
    },
    "GLUT Keyboard Callback": {
        "prefix": [
            "glut_keyboard",
            "keyboard_func"
        ],
        "body": [
            "void ${1:keyboard}(unsigned char key, int x, int y)",
            "{",
            "    switch (key) {",
            "        case 27: // ESC",
            "            exit(0);",
            "            break;",
            "        case ' ': // Space",
            "            $0",
            "            break;",
            "    }",
            "    glutPostRedisplay();",
            "}"
        ],
        "description": "GLUT keyboard callback with ESC quit and space handler"
    },
    "GLUT Special Keys Callback": {
        "prefix": [
            "glut_special",
            "special_func"
        ],
        "body": [
            "void ${1:specialKeys}(int key, int x, int y)",
            "{",
            "    switch (key) {",
            "        case GLUT_KEY_UP:",
            "            $0",
            "            break;",
            "        case GLUT_KEY_DOWN:",
            "            break;",
            "        case GLUT_KEY_LEFT:",
            "            break;",
            "        case GLUT_KEY_RIGHT:",
            "            break;",
            "    }",
            "    glutPostRedisplay();",
            "}"
        ],
        "description": "GLUT special keys callback (arrow keys)"
    },
