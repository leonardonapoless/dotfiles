    "GLUT Timer Animation": {
        "prefix": [
            "glut_timer",
            "timer_func"
        ],
        "body": [
            "static float ${1:angle} = 0.0f;",
            "",
            "void ${2:timer}(int value)",
            "{",
            "    ${1} += ${3:1.0f};",
            "    if (${1} > 360.0f) ${1} -= 360.0f;",
            "    glutPostRedisplay();",
            "    glutTimerFunc(${4:16}, ${2}, 0); // ~60 FPS",
            "}",
            "",
            "// In main(): glutTimerFunc(0, ${2}, 0);"
        ],
        "description": "GLUT timer callback for smooth animation (~60 FPS)"
    },
    "GLUT Idle Animation": {
        "prefix": [
            "glut_idle",
            "idle_func"
        ],
        "body": [
            "void ${1:idle}(void)",
            "{",
            "    $0",
